# URL of the deployed FastAPI backend (agentic-contract-review/api)
# In Vercel, set this to your Railway or hosted API URL.
# Local development can omit this and use the built-in localhost fallback,
# or set VITE_API_URL=http://localhost:8000 in .env.local.
VITE_API_URL=https://your-contract-review-api.example.com
